#!/bin/sh
# Scan staged files for anti-hack markers before allowing a commit (this is a PUBLIC repo).
# Anti-hack must live only in the game repo as private *.Security.cs partials, never here.
# Exclude this hook dir (it contains the patterns as search terms).
staged=$(git diff --cached --name-only --diff-filter=ACM | grep -v -e '^.githooks/')
[ -z "$staged" ] && exit 0
if printf '%s\n' "$staged" | tr '\n' '\0' | xargs -0 -r grep -lI -e 'PROTECTION' -e 'HashControlled' -e 'hash_capture' 2>/dev/null; then
  echo "ERROR: anti-hack marker found in the files above. This is a PUBLIC repo; commit aborted." >&2
  exit 1
fi
exit 0
